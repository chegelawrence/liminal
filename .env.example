# ── AI providers ─────────────────────────────────────────────────────────────
# Only the key for your chosen provider is required.
# Set ai.provider in config.yaml to select which one to use.

# "claude" provider (default) — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# "openai" provider — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# "groq" provider (free tier) — https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# "ollama" provider — no key needed, just run: ollama serve

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://liminal:password@localhost:5432/liminal

# ── Notifications (all optional) ─────────────────────────────────────────────

# Slack incoming webhook URL
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Discord incoming webhook URL
# Create one in: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# SMTP password (used when notifications.smtp_host is set in config YAML)
SMTP_PASSWORD=
