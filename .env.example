# ── AI providers ─────────────────────────────────────────────────────────────

# Required for Claude provider (default)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Required for OpenAI provider (set ai.provider: "openai" in config.yaml)
OPENAI_API_KEY=your_openai_key_here

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://bugbounty:password@localhost:5432/bugbounty

# ── Notifications (all optional) ─────────────────────────────────────────────

# Slack incoming webhook URL
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Discord incoming webhook URL
# Create one in: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# SMTP password (used when notifications.smtp_host is set in config YAML)
SMTP_PASSWORD=
